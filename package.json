{
  "name": "VueHooksKit",
  "version": "1.0.0",
  "private": false,
  "description": "A high-reuse, type-safe, atomic-style compatible Vue 3 Hooks collection",
  "main": "dist/vue-hooks-kit.umd.js",
  "module": "dist/vue-hooks-kit.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "docs:dev": "vitepress dev docs",
    "build:docs": "tsx scripts/build-docs.ts",
    "docs:build": "pnpm run build:docs && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky install",
    "pub": "pnpm run lint && pnpm run test && pnpm run build && npm publish"
  },
  "dependencies": {
    "@vueuse/core": "^10.0.0",
    "axios": "^1.6.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@iconify-json/carbon": "^1.2.19",
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/node": "^18.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.0",
    "eslint": "^8.50.0",
    "eslint-plugin-vue": "^9.0.0",
    "husky": "^8.0.0",
    "jsdom": "^23.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.2.0",
    "unocss": "^0.58.0",
    "unplugin-auto-import": "^0.17.0",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.0.0",
    "vitepress": "^1.0.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^1.8.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,vue,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
