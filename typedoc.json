{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/hooks/index.ts"],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "hideGenerator": true,
  "readme": "none",
  "cleanOutputDir": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "exclude": ["**/__tests__/**"],
  "skipErrorChecking": true
}
